{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "usermeta": {
    "deneb": {
      "build": "1.4.0.0",
      "metaVersion": 1,
      "provider": "vegaLite",
      "providerVersion": "5.4.0"
    },
    "interactivity": {
      "tooltip": true,
      "contextMenu": true,
      "selection": true,
      "highlight": true,
      "dataPointLimit": 50
    },
    "information": {
      "name": "Bullet Chart com multi rótulos",
      "description": "[No Description Provided]",
      "author": "Jefferson Alves",
      "uuid": "37623e6a-ffea-4689-ae83-aca2e996eb14",
      "generated": "2023-03-23T12:12:17.279Z",
      "previewImageBase64PNG": "data:image/png;base64,"
    },
    "dataset": [
      {
        "key": "__0__",
        "name": "Categoria",
        "description": "Coluna que será o eixo do visual",
        "type": "text",
        "kind": "column"
      },
      {
        "key": "__1__",
        "name": "Realizado (valor)",
        "description": "",
        "type": "numeric",
        "kind": "measure"
      },
      {
        "key": "__2__",
        "name": "Meta (valor)",
        "description": "",
        "type": "numeric",
        "kind": "measure"
      },
      {
        "key": "__3__",
        "name": "Realizado (porcentagem)",
        "description": "",
        "type": "numeric",
        "kind": "measure"
      }
    ]
  },
  "config": {
    "view": {"stroke": "transparent"},
    "font": "Segoe UI",
    "axis": {
      "ticks": false,
      "grid": false,
      "domain": false,
      "labelColor": "#b3b3b3",
      "labelFontSize": 12
    },
    "axisX": {"labelPadding": 5},
    "axisY": {"labelPadding": 10},
    "padding": { "right": 15 } 
  },
  "data": {"name": "dataset"},
  "height": {"step": 65},
  "transform": [
    {
      "calculate": "datum['__1__'] >= datum['__2__']",
      "as": "fat_positivo"
    },
    {
      "calculate": " datum.fat_positivo ? '#26969F' : '#BF5064'  ",
      "as": "barra_prog_cor"
    }
  ],


  "params": [
    { "name": "barra_meta_cor", "value": "#3D464F" },

    { "name": "rot_porc_tam", "value": 10 },
    { "name": "rot_porc_cor",  "value": "#f1f1f1" },
    { "name": "rot_porc_peso",  "value": 600  },

    { "name": "rot_valor_tam",   "value": 10  },
    { "name": "rot_valor_peso",  "value": 600 },
    { "name": "rot_valor_pos",   "value": -15 },

    { "name": "rot_meta_cor", "value": "#838383" },
    { "name": "rot_meta_tam", "value": 10 },
    { "name": "rot_meta_peso", "value": 600  },
    { "name": "rot_meta_pos",  "value": 16  }

  ],


  "encoding": {
    "y": {
      "field": "__0__",
      "type": "nominal",
      "sort": {
        "field": "__1__",
        "order": "descending",
        "op": "sum"
      },
      "axis": {"title": null}
    },
    "x": {
      "type": "quantitative",
      "axis": null
    },
    "opacity": {
      "condition": {
        "test": {
          "field": "__selected__",
          "equal": "off"
        },
        "value": 0.3
      },
      "value": 1
    },

    "tooltip": [
      { "field": "Vendedor" }, 
      { "field": "Faturamento" }, 
      { "field": "Meta" }, 
      { "field": "Porcentagem Meta" }
      
    ]    

  },
  "layer": [
    {
      "description": " **************** BARRA META **************** ",
      "mark": {
        "type": "bar",
        "height": {"band": 0.48},
        "cornerRadius": 3,
        "color": {
          "expr": "barra_meta_cor"
        }
      },
      "encoding": {
        "x": {"field": "__2__"}
      }
    },
    {
      "description": " **************** BARRA PROGRESSO  **************** ",
      "mark": {
        "type": "bar",
        "height": {"band": 0.32},
        "cornerRadius": 3,
        "color": {
          "expr": "datum.barra_prog_cor"
        }
      },
      "encoding": {
        "x": {"field": "__1__"}
      }
    },
    {
      "description": " **************** Rótulo Porc. Meta  **************** ",
      "mark": {
        "type": "text",
        "color": {
          "expr": "rot_porc_cor"
        },
        "align": "left",
        "baseline": "middle",
        "dx": 3,
        "fontSize": {
          "expr": "rot_porc_tam"
        },
        "fontWeight": {
          "expr": "rot_porc_peso"
        }
      },
      "encoding": {
        "text": {
          "field": "__3__",
          "format": ".3~p"
        },
        "x": {"datum": 0}
      }
    },
    {
      "description": " **************** Rotulo Valor Fat  **************** ",
      "mark": {
        "type": "text",
        "color": {
          "expr": "datum.barra_prog_cor"
        },
        "align": "center",
        "baseline": "bottom",
        "dx": 0,
        "dy": {"expr": "rot_valor_pos"},
        "fontSize": {
          "expr": "rot_valor_tam"
        },
        "fontWeight": {
          "expr": "rot_valor_peso"
        }
      },
      "encoding": {
        "text": {
          "field": "__1__",
          "format": ".3~s"
        },
        "x": {"field": "__1__"}
      }
    },
    {
      "description": " **************** Rotulo Valor Meta  **************** ",
      "mark": {
        "type": "text",
        "color": {
          "expr": "rot_meta_cor"
        },
        "align": "center",
        "baseline": "top",
        "dx": 0,
        "dy": {"expr": "rot_meta_pos"},
        "fontSize": {
          "expr": "rot_meta_tam"
        },
        "fontWeight": {
          "expr": "rot_meta_peso"
        }
      },
      "encoding": {
        "text": {
          "field": "__2__",
          "format": ".3~s"
        },
        "x": {"field": "__2__"}
      }
    }
  ]
}