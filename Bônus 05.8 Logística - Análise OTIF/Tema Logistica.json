                        "color": "#7B93A6"
                     }
                  },
                  "transparency": 0
               }
            ]
         }
      },
      "page": {
         "*": {
            "background": [
               {
                  "color": {
                     "solid": {
                        "color": "#FFFFFF"
                     }
                  },
                  "transparency": 100
               }
            ],
            "outspace": [
               {
                  "transparency": 100
               }
            ]
         }
