                     }
                  },
                  "actionFontColor": {
                     "solid": {
                        "color": "#F1F1F1"
                     }
                  }
               }
            ],
            "visualHeaderTooltip": [
               {
                  "themedTitleFontColor": {
                     "solid": {
                        "color": "#C8C8C8"
                     }
                  },
                  "themedBackground": {
                     "solid": {
                        "color": "#02101B",
                        "opacity": 0.5
                     }
                  }
               }
            ],
            "outspacePane": [
               {
                  "backgroundColor": {
                     "solid": {
                        "color": "#02101B"
                     }
                  },
                  "foregroundColor": {
                     "solid": {
                        "color": "#F1F1F1"
                     }
                  }
               }
            ],
            "filterCard": [
               {
